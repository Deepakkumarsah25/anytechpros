<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>AnyTechPros | About — Policy to Execution</title>
    <link rel="stylesheet" href="/css/common/header.css">
<link rel="stylesheet" href="/css/common/footer.css">
 <link rel="stylesheet" href="/css/about/about.css">
</head>
<body>
 <%- include("../common/header.ejs") %>
<!-- Hero Section with brand story headline -->
<section class="hero">
  <div class="container">
    <h1>Built to move complex programs <br>from <span>policy to execution</span></h1>
    <p>AnyTechPros exists to bridge the gap between government vision and on-ground delivery — with speed, structure, and accountability.</p>
    <!-- Values block -->
    <div class="values-row">
      <span class="value-pill">⚖️ Governance-first</span>
      <span class="value-pill">🎯 Execution-owned</span>
      <span class="value-pill">📋 Compliance-aware</span>
      <span class="value-pill">🏗️ Built for complexity</span>
    </div>
  </div>
</section>

<!-- Proof Snapshot -->
<div class="container">
  <div class="proof-snapshot">
    <p>📌 <strong>15+ States Covered</strong> | Government Advisory + Delivery Experience | Procurement, Contracts, PMU, Telecom, IT, ERP | Public-Sector and Enterprise Exposure</p>
  </div>
</div>

<!-- How We Work -->
<section>
  <div class="container">
    <div class="section-label">How we work</div>
    <h2 class="section-title">From ambiguity to clarity,<br>in four deliberate steps</h2>
    <div class="steps-grid">
      <div class="step"><div class="step-icon">🔍</div><h3>Understand</h3><p>Deep-dive into context, stakeholders, and constraints</p></div>
      <div class="step"><div class="step-icon">📐</div><h3>Structure</h3><p>Build governance frameworks, procurement plans, and PMU</p></div>
      <div class="step"><div class="step-icon">⚙️</div><h3>Execute</h3><p>Deploy technology, manage contracts, drive implementation</p></div>
      <div class="step"><div class="step-icon">📈</div><h3>Strengthen</h3><p>Monitor, optimize, and scale for lasting impact</p></div>
    </div>
  </div>
</section>

<!-- Leadership section -->
<section>
  <div class="container">
    <div class="section-label">Leadership</div>
    <h2 class="section-title">Driven by experience,<br>rooted in public sector</h2>
    <div class="leadership-grid">
      <!-- Leader 1 -->
      <div class="leader-card">
        <div class="leader-photo">👩‍💼</div>
        <div class="leader-name">Anjali Sharma</div>
        <div class="leader-role">CEO & Founder</div>
        <div class="capability-tags">
          <span class="tag">Public Policy</span>
          <span class="tag">Procurement Strategy</span>
          <span class="tag">PMU Setup</span>
        </div>
      </div>
      <!-- Leader 2 -->
      <div class="leader-card">
        <div class="leader-photo">👨‍💻</div>
        <div class="leader-name">Rajat Verma</div>
        <div class="leader-role">CTO</div>
        <div class="capability-tags">
          <span class="tag">Enterprise Tech</span>
          <span class="tag">Telecom Consulting</span>
          <span class="tag">Cybersecurity</span>
        </div>
      </div>
      <!-- Leader 3 -->
      <div class="leader-card">
        <div class="leader-photo">👩‍🔧</div>
        <div class="leader-name">Priya Menon</div>
        <div class="leader-role">Head of Delivery</div>
        <div class="capability-tags">
          <span class="tag">Program Governance</span>
          <span class="tag">Contract Management</span>
          <span class="tag">Compliance</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Sectors Served -->
<section>
  <div class="container">
    <div class="section-label">Sectors served</div>
    <h2 class="section-title">Where we deliver impact</h2>
    <div class="sectors-grid">
      <span class="sector-pill">Government Departments</span>
      <span class="sector-pill">PSUs</span>
      <span class="sector-pill">Telecom</span>
      <span class="sector-pill">Smart Infrastructure</span>
      <span class="sector-pill">Enterprise Technology</span>
      <span class="sector-pill">Skill Development</span>
      <span class="sector-pill">BFSI</span>
      <span class="sector-pill">Public Digital Systems</span>
    </div>
  </div>
</section>

<!-- Final CTA -->
<section class="cta-section">
  <div class="container">
    <h2 style="font-size: clamp(28px, 5vw, 42px); font-weight: 700;">Ready to move from policy to execution?</h2>
    <p style="color: var(--muted); margin-top: 12px;">Let’s discuss how AnyTechPros can accelerate your next initiative.</p>
    <a href="/contect" class="btn-primary">📞 Talk to Our Team →</a>
  </div>
</section>

<!-- simple footer note (no navigation) -->
 <%- include("../common/footer.ejs") %>
</body>
</html>