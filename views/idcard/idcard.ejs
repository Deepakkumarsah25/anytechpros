<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RID Tech — ID Card Generator</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:"Segoe UI",sans-serif;background:#e8eef6;min-height:100vh;padding:20px;}
h2{font-size:22px;font-weight:600;color:#1a2744;margin-bottom:20px;text-align:center;}
.container{max-width:700px;margin:0 auto;background:#fff;border-radius:16px;padding:28px;box-shadow:0 4px 24px rgba(0,0,0,.1);}
.form-panel{display:flex;flex-direction:column;gap:13px;}
.field-group label{font-size:12px;color:#4a5a7a;margin-bottom:4px;display:block;font-weight:600;}
.uid-display{width:100%;padding:9px 12px;border:1px dashed #1a6cc4;border-radius:8px;font-size:14px;color:#1a6cc4;background:#f0f6ff;font-weight:700;letter-spacing:1px;min-height:38px;display:flex;align-items:center;}
input[type=text],select{width:100%;padding:9px 12px;border:1px solid #c8d5e8;border-radius:8px;font-size:14px;color:#1a2744;background:#f8fafd;outline:none;transition:border .2s;}
input:focus,select:focus{border-color:#1a6cc4;background:#fff;box-shadow:0 0 0 3px #1a6cc420;}
.photo-upload{border:2px dashed #b0c4de;border-radius:10px;padding:14px;text-align:center;cursor:pointer;background:#f4f8fd;transition:border .2s;}
.photo-upload:hover{border-color:#1a6cc4;}
.photo-placeholder{width:72px;height:72px;border-radius:50%;background:#d0e8f7;display:flex;align-items:center;justify-content:center;margin:0 auto 6px;font-size:30px;color:#1a6cc4;}
.gen-btn{width:100%;padding:14px;background:#1a6cc4;color:#fff;border:none;border-radius:9px;font-size:16px;font-weight:700;cursor:pointer;margin-top:4px;transition:background .2s;}
.gen-btn:hover{background:#155aa0;}
#previewPage{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:#0d1a35;z-index:1000;overflow-y:auto;padding:30px 20px 40px;}
.preview-header{display:flex;align-items:center;justify-content:space-between;max-width:760px;margin:0 auto 24px;}
.preview-header h3{font-size:18px;font-weight:700;color:#fff;}
.back-btn{padding:8px 18px;background:rgba(255,255,255,.12);color:#fff;border:1px solid rgba(255,255,255,.25);border-radius:8px;cursor:pointer;font-size:13px;font-weight:600;transition:background .2s;}
.back-btn:hover{background:rgba(255,255,255,.22);}
.cards-wrapper{display:flex;gap:28px;justify-content:center;flex-wrap:wrap;max-width:760px;margin:0 auto 28px;}
.card-col{display:flex;flex-direction:column;align-items:center;gap:10px;}
.card-col-label{font-size:11px;font-weight:700;color:#7a9bcc;letter-spacing:2px;text-transform:uppercase;}
.dl-section{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;max-width:760px;margin:0 auto;}
.dl-btn{padding:12px 28px;border:none;border-radius:9px;font-size:14px;font-weight:700;cursor:pointer;transition:background .2s;display:flex;align-items:center;gap:8px;}
.dl-front{background:#1a6cc4;color:#fff;}.dl-front:hover{background:#155aa0;}
.dl-back{background:#0f6e56;color:#fff;}.dl-back:hover{background:#085041;}
.dl-both{background:#d4a828;color:#1a2744;}.dl-both:hover{background:#b88e1a;}
.card{width:300px;height:440px;border-radius:18px;overflow:hidden;box-shadow:0 8px 32px rgba(0,0,0,.30);font-family:"Segoe UI",sans-serif;position:relative;}
.card-front{background:linear-gradient(155deg,#2c8ae0 0%,#1a5a9c 50%,#122f6b 100%);color:#fff;display:flex;flex-direction:column;}
.wave-bg{position:absolute;top:0;left:0;right:0;bottom:0;overflow:hidden;pointer-events:none;}
.wave-bg svg{position:absolute;top:0;left:0;width:100%;opacity:.12;}
.front-top{padding:20px 20px 10px;text-align:center;position:relative;z-index:1;flex-shrink:0;}
.org-badge{display:inline-block;background:rgba(255,255,255,.15);border-radius:20px;padding:3px 16px;font-size:10px;letter-spacing:2px;color:#c8dff5;margin-bottom:12px;text-transform:uppercase;border:1px solid rgba(255,255,255,.22);}
.photo-circle{width:90px;height:90px;border-radius:50%;border:3px solid #d4a828;background:#c5daf0;margin:0 auto 10px;overflow:hidden;display:flex;align-items:center;justify-content:center;}
.photo-circle img{width:100%;height:100%;object-fit:cover;}
.photo-icon{font-size:38px;color:#1a5a9c;}
.member-name{font-size:19px;font-weight:700;color:#fff;letter-spacing:.5px;text-shadow:0 1px 4px rgba(0,0,0,.25);}
.card-bottom{background:#f0f6ff;color:#1a2744;padding:12px 18px 10px;position:relative;z-index:1;flex:1;display:flex;flex-direction:column;justify-content:space-between;}
.role-label{color:#d4a828;font-weight:700;font-size:13px;margin-bottom:8px;}
.field-row{display:flex;justify-content:space-between;align-items:center;font-size:12px;margin-bottom:5px;}
.field-key{color:#4a5a7a;font-weight:600;}
.field-sep{color:#8a9bba;margin:0 4px;}
.field-val{color:#1a6cc4;font-weight:600;}
.qr-row{display:flex;justify-content:flex-end;margin-top:6px;}
.watermark{font-size:9px;color:rgba(255,255,255,.35);position:absolute;bottom:6px;left:12px;z-index:2;}
.card-back{background:#f0f5ff;display:flex;flex-direction:column;}
.back-logo-bar{background:#fff;text-align:center;padding:14px 0 10px;border-bottom:1px solid #d0daea;flex-shrink:0;}
/* CIRCLE LOGO */
.back-logo-circle-wrap{width:82px;height:82px;border-radius:50%;overflow:hidden;margin:0 auto;border:3px solid #d4a828;background:#1a2744;display:flex;align-items:center;justify-content:center;}
.back-logo-img{width:100%;height:100%;object-fit:cover;border-radius:50%;}
.back-info{background:linear-gradient(135deg,#1a5a9c,#122f6b);color:#fff;margin:8px 12px;border-radius:10px;padding:12px 14px;flex-shrink:0;}
.back-uid-label{font-size:11px;color:#a8d0ef;margin-bottom:2px;}
.back-uid-val{font-size:15px;font-weight:700;color:#fff;margin-bottom:8px;}
.back-valid-label{font-size:11px;color:#a8d0ef;margin-bottom:2px;}
.back-valid-val{font-size:13px;font-weight:700;color:#fff;}
.back-qr-right{float:right;margin-left:10px;}
.tc-section{padding:8px 12px 4px;flex-shrink:0;}
.tc-title{font-size:11px;font-weight:700;color:#1a2744;margin-bottom:5px;}
.tc-item{font-size:9.5px;color:#4a5a7a;display:flex;gap:4px;margin-bottom:3px;line-height:1.4;}
.tc-check{color:#1a6cc4;font-weight:700;flex-shrink:0;}
.addr-section{padding:3px 12px 6px;flex-shrink:0;}
.addr-title{font-size:11px;font-weight:700;color:#1a2744;margin-bottom:2px;}
.addr-val{font-size:9.5px;color:#4a5a7a;line-height:1.5;}
.web-footer{text-align:center;font-size:9.5px;color:#8a9bba;padding:5px 0 8px;border-top:1px solid #d0daea;margin-top:auto;}
.loading-overlay{display:none;position:fixed;inset:0;background:rgba(13,26,53,.85);z-index:2000;align-items:center;justify-content:center;flex-direction:column;gap:16px;}
.loading-overlay.show{display:flex;}
.spinner{width:44px;height:44px;border:4px solid rgba(255,255,255,.2);border-top-color:#fff;border-radius:50%;animation:spin .8s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}
.loading-overlay p{color:#fff;font-size:15px;font-weight:600;}
</style>
</head>
<body>
<div class="container" id="formPage">
  <h2>&#127994; RID Tech &#8212; ID Card Generator</h2>
  <div class="form-panel">
    <div class="field-group"><label>Full Name</label><input id="f-name" type="text" placeholder="e.g. Deepak Kumar Sah"></div>
    <div class="field-group">
      <label>Designation / Role</label>
      <select id="f-role">
        <option value="">-- Select Role --</option>
        <optgroup label="Management">
          <option>Chief Executive Officer (CEO)</option><option>Chief Technology Officer (CTO)</option>
          <option>Chief Operating Officer (COO)</option><option>Chief Financial Officer (CFO)</option>
          <option>Chief Marketing Officer (CMO)</option><option>Chief Product Officer (CPO)</option>
          <option>Vice President</option><option>Director</option><option>General Manager</option>
          <option>Project Manager</option><option>Product Manager</option><option>Team Leader</option>
        </optgroup>
        <optgroup label="Engineering & Development">
          <option>Software Engineer</option><option>Senior Software Engineer</option>
          <option>Lead Software Engineer</option><option>Full Stack Developer</option>
          <option>Frontend Developer</option><option>Backend Developer</option>
          <option>Mobile App Developer</option><option>Android Developer</option><option>iOS Developer</option>
          <option>DevOps Engineer</option><option>Cloud Engineer</option>
          <option>Site Reliability Engineer</option><option>Embedded Systems Engineer</option>
          <option>Firmware Engineer</option>
        </optgroup>
        <optgroup label="Data & AI">
          <option>Data Scientist</option><option>Data Analyst</option><option>Data Engineer</option>
          <option>Machine Learning Engineer</option><option>AI Engineer</option>
          <option>Business Intelligence Analyst</option>
        </optgroup>
        <optgroup label="Design & UX">
          <option>UI/UX Designer</option><option>Graphic Designer</option><option>Product Designer</option>
          <option>Motion Designer</option><option>Visual Designer</option>
        </optgroup>
        <optgroup label="Quality & Testing">
          <option>QA Engineer</option><option>QA Analyst</option><option>Test Lead</option>
          <option>Automation Engineer</option>
        </optgroup>
        <optgroup label="Security">
          <option>Cybersecurity Analyst</option><option>Security Engineer</option>
          <option>Penetration Tester</option><option>Information Security Officer</option>
        </optgroup>
        <optgroup label="Networking & IT">
          <option>Network Engineer</option><option>System Administrator</option>
          <option>IT Support Engineer</option><option>Database Administrator</option>
        </optgroup>
        <optgroup label="Sales & Marketing">
          <option>Business Development Executive</option><option>Sales Executive</option>
          <option>Marketing Executive</option><option>Digital Marketing Specialist</option>
          <option>SEO Specialist</option><option>Content Writer</option>
          <option>Social Media Manager</option><option>Brand Manager</option>
        </optgroup>
        <optgroup label="HR & Administration">
          <option>HR Manager</option><option>HR Executive</option><option>Recruiter</option>
          <option>Admin Executive</option><option>Office Manager</option>
        </optgroup>
        <optgroup label="Finance & Accounts">
          <option>Finance Manager</option><option>Accountant</option>
          <option>Financial Analyst</option><option>Accounts Executive</option>
        </optgroup>
        <optgroup label="Customer Support">
          <option>Customer Support Executive</option><option>Technical Support Specialist</option>
          <option>Customer Success Manager</option>
        </optgroup>
        <optgroup label="Intern & Trainee">
          <option>Software Intern</option><option>Design Intern</option><option>Marketing Intern</option>
          <option>HR Intern</option><option>Trainee Engineer</option><option>Management Trainee</option>
        </optgroup>
      </select>
    </div>
    <div class="field-group">
      <label>Unique ID <span style="color:#1a6cc4;font-size:11px">(Auto-generated on card creation)</span></label>
      <div class="uid-display" id="uid-preview">Will be generated automatically</div>
    </div>
    <div class="field-group"><label>Date of Birth</label><input id="f-dob" type="text" placeholder="DD/MM/YYYY" maxlength="10"></div>
    <div class="field-group">
      <label>Blood Group</label>
      <select id="f-blood"><option>O+</option><option>O-</option><option>A+</option><option>A-</option><option>B+</option><option>B-</option><option>AB+</option><option>AB-</option></select>
    </div>
    <div class="field-group"><label>Validity Date</label><input id="f-valid" type="text" placeholder="DD/MM/YYYY" value="01/01/2027" maxlength="10"></div>
    <div class="field-group"><label>Organization Name</label><input id="f-org" type="text" placeholder="RID TECH" value="RID TECH"></div>
    <div class="field-group"><label>Office Address</label><input id="f-addr" type="text" value="51 Sector C, Indrapuri, Raisen Road Bhopal, 462022"></div>
    <div class="field-group"><label>Website / QR Code URL</label><input id="f-web" type="text" value="https://www.ridtech.in"></div>
    <div class="field-group">
      <label>Photo</label>
      <div class="photo-upload" onclick="document.getElementById('photoInput').click()">
        <div class="photo-placeholder" id="photoPlaceholder">&#128247;</div>
        <img id="photoPreview" style="display:none;width:72px;height:72px;border-radius:50%;object-fit:cover;margin:0 auto 6px;border:3px solid #d4a828;">
        <div style="font-size:12px;color:#8a9bba;margin-top:4px" id="photoLabel">Click to upload photo</div>
      </div>
      <input type="file" id="photoInput" accept="image/*" style="display:none">
    </div>
    <button class="gen-btn" onclick="generateCard()">&#9654; Generate ID Card</button>
  </div>
</div>

<div id="previewPage">
  <div class="preview-header">
    <h3>&#127994; ID Card Preview</h3>
    <button class="back-btn" onclick="goBack()">&#8592; Back to Form</button>
  </div>
  <div class="cards-wrapper">
    <div class="card-col">
      <div class="card-col-label">Front</div>
      <div class="card card-front" id="cardFront">
        <div class="wave-bg">
          <svg viewBox="0 0 300 200" xmlns="http://www.w3.org/2000/svg">
            <path d="M0,80 Q90,20 180,90 Q260,160 300,60 L300,0 L0,0 Z" fill="#fff"/>
            <path d="M0,150 Q110,95 210,155 Q265,178 300,135 L300,200 L0,200 Z" fill="#fff"/>
          </svg>
        </div>
        <div class="front-top">
          <div class="org-badge" id="p-org">RID TECH</div>
          <div class="photo-circle">
            <img id="p-photo" style="display:none;width:100%;height:100%;object-fit:cover;">
            <span class="photo-icon" id="p-photo-icon">&#128100;</span>
          </div>
          <div class="member-name" id="p-name">&#8212;</div>
        </div>
        <div class="card-bottom">
          <div>
            <div class="role-label" id="p-role">&#8212;</div>
            <div class="field-row"><span class="field-key">Unique ID</span><span class="field-sep">:</span><span class="field-val" id="p-uid">&#8212;</span></div>
            <div class="field-row"><span class="field-key">Date Of Birth</span><span class="field-sep">:</span><span class="field-val" id="p-dob">&#8212;</span></div>
            <div class="field-row"><span class="field-key">Blood Group</span><span class="field-sep">:</span><span class="field-val" id="p-blood">&#8212;</span></div>
          </div>
          <div class="qr-row" id="qrFrontContainer"></div>
        </div>
        <div class="watermark" id="p-web-wm">www.ridtech.in</div>
      </div>
    </div>
    <div class="card-col">
      <div class="card-col-label">Back</div>
      <div class="card card-back" id="cardBack">
        <div class="back-logo-bar">
          <div class="back-logo-circle-wrap">
            <img class="back-logo-img" id="backLogoImg" src="" alt="RID TECH">
          </div>
        </div>
        <div class="back-info">
          <div style="overflow:hidden">
            <div class="back-qr-right" id="qrBackContainer"></div>
            <div class="back-uid-label">Unique ID</div>
            <div class="back-uid-val" id="p-uid-back">&#8212;</div>
            <div class="back-valid-label">Validity</div>
            <div class="back-valid-val" id="p-valid">&#8212;</div>
          </div>
        </div>
        <div class="tc-section">
          <div class="tc-title">Terms &amp; Conditions</div>
          <div class="tc-item"><span class="tc-check">&#10003;</span><span>Always wear visibly inside premises.</span></div>
          <div class="tc-item"><span class="tc-check">&#10003;</span><span>Lost or damaged cards must be reported to HR/Admin.</span></div>
          <div class="tc-item"><span class="tc-check">&#10003;</span><span>Misuse of this card may result in disciplinary action.</span></div>
          <div class="tc-item"><span class="tc-check">&#10003;</span><span>This card is non-transferable and for official use only.</span></div>
          <div class="tc-item"><span class="tc-check">&#10003;</span><span>Please return the card upon resignation or termination.</span></div>
        </div>
        <div class="addr-section">
          <div class="addr-title">Office Address</div>
          <div class="addr-val" id="p-addr">&#8212;</div>
        </div>
        <div class="web-footer" id="p-web-footer">www.ridtech.in</div>
      </div>
    </div>
  </div>
  <div class="dl-section">
    <button class="dl-btn dl-front" onclick="downloadCard('cardFront','RID_ID_Front.png')">&#11015; Download Front (HD)</button>
    <button class="dl-btn dl-back"  onclick="downloadCard('cardBack','RID_ID_Back.png')">&#11015; Download Back (HD)</button>
    <button class="dl-btn dl-both" onclick="downloadBoth()">&#11015; Download Both</button>
  </div>
</div>

<div class="loading-overlay" id="loadingOverlay">
  <div class="spinner"></div>
  <p>Generating HD Image...</p>
</div>

<script>
const LOGO_SRC="data:image/png;base64,";
let photoDataUrl=null;
let uidCounter=parseInt(localStorage.getItem("rid_uid_counter")||"1");
document.getElementById("backLogoImg").src=LOGO_SRC;
document.getElementById("photoInput").addEventListener("change",function(e){
  const file=e.target.files[0];if(!file)return;
  const r=new FileReader();
  r.onload=function(ev){
    photoDataUrl=ev.target.result;
    const prev=document.getElementById("photoPreview");
    prev.src=photoDataUrl;prev.style.display="block";
    document.getElementById("photoPlaceholder").style.display="none";
    document.getElementById("photoLabel").textContent="Photo uploaded ✓";
  };r.readAsDataURL(file);
});
function generateUID(){
  const num=String(uidCounter).padStart(5,"0");
  const uid="RIDM2025"+num;
  uidCounter++;localStorage.setItem("rid_uid_counter",uidCounter);return uid;
}
function makeQR(cid,url,size){
  const c=document.getElementById(cid);c.innerHTML="";
  new QRCode(c,{text:url||"https://www.ridtech.in",width:size,height:size,colorDark:"#1a2744",colorLight:"#ffffff",correctLevel:QRCode.CorrectLevel.M});
}
function generateCard(){
  const name=document.getElementById("f-name").value.trim();
  const role=document.getElementById("f-role").value;
  const dob=document.getElementById("f-dob").value.trim();
  const blood=document.getElementById("f-blood").value;
  const valid=document.getElementById("f-valid").value.trim();
  const org=document.getElementById("f-org").value.trim()||"RID TECH";
  const addr=document.getElementById("f-addr").value.trim();
  const web=document.getElementById("f-web").value.trim()||"https://www.ridtech.in";
  const webDisp=web.replace(/^https?:\/\//,"");
  if(!name){alert("Please enter Full Name");return;}
  if(!role){alert("Please select a Role / Designation");return;}
  if(!dob){alert("Please enter Date of Birth");return;}
  const uid=generateUID();
  document.getElementById("uid-preview").textContent=uid;
  document.getElementById("p-name").textContent=name;
  document.getElementById("p-role").textContent=role;
  document.getElementById("p-uid").textContent=uid;
  document.getElementById("p-dob").textContent=dob;
  document.getElementById("p-blood").textContent=blood;
  document.getElementById("p-org").textContent=org;
  document.getElementById("p-uid-back").textContent=uid;
  document.getElementById("p-valid").textContent=valid||"--";
  document.getElementById("p-addr").textContent=addr||"--";
  document.getElementById("p-web-footer").textContent=webDisp;
  document.getElementById("p-web-wm").textContent=webDisp;
  if(photoDataUrl){
    const pi=document.getElementById("p-photo");
    pi.src=photoDataUrl;pi.style.display="block";
    document.getElementById("p-photo-icon").style.display="none";
  }else{
    document.getElementById("p-photo").style.display="none";
    document.getElementById("p-photo-icon").style.display="inline";
  }
  document.getElementById("formPage").style.display="none";
  document.getElementById("previewPage").style.display="block";
  window.scrollTo(0,0);
  setTimeout(()=>{makeQR("qrFrontContainer",web,58);makeQR("qrBackContainer",web,66);},300);
}
function goBack(){
  document.getElementById("previewPage").style.display="none";
  document.getElementById("formPage").style.display="block";
}
function downloadCard(id,filename){
  const ov=document.getElementById("loadingOverlay");ov.classList.add("show");
  setTimeout(()=>{
    html2canvas(document.getElementById(id),{scale:4,useCORS:true,allowTaint:true,backgroundColor:null,logging:false})
    .then(canvas=>{
      ov.classList.remove("show");
      const a=document.createElement("a");a.download=filename;a.href=canvas.toDataURL("image/png",1.0);a.click();
    }).catch(()=>ov.classList.remove("show"));
  },200);
}
function downloadBoth(){
  downloadCard("cardFront","RID_ID_Front.png");
  setTimeout(()=>downloadCard("cardBack","RID_ID_Back.png"),2000);
}
</script>
</body>
</html>



Case Studies