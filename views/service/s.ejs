<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
<title>AnyTechPros | Our Services</title>
 <link rel="stylesheet" href="css/common/footer.css">
 <link rel="stylesheet" href="css/common/header.css">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Syne:wght@600;700;800&family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
<style>

*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --black:#0c0f0f;--black-soft:#121616;
  --olive:#4f7a3b;--olive-l:#7aa55a;--olive-d:#3a5c2a;--olive-glow:rgba(79,122,59,0.18);
  --white:#ffffff;--gray-light:rgba(255,255,255,0.75);--border:rgba(79,122,59,0.35);
  --teal:#2d9c7c;--teal-l:#4bc0a0;--teal-d:#1e6b55;
  --muted:#b0c4c2;--card-bg:rgba(18,24,27,0.92);--card-border:rgba(45,156,124,0.25);
}
html{scroll-behavior:smooth;overflow-x:hidden}
body{background:#0b0e0e;font-family:'Inter','DM Sans',system-ui,sans-serif;color:var(--white);line-height:1.45;overflow-x:hidden;min-height:100vh}

/* =========================================================
   HERO
   ========================================================= */
.page-hero{
  padding:80px 5rem 70px;
  background:linear-gradient(160deg,#0b0e0e 0%,#0d1a17 50%,#0a1310 100%);
  position:relative;overflow:hidden;border-bottom:1px solid var(--border);
}
.page-hero::before{
  content:'';position:absolute;inset:0;pointer-events:none;
  background:radial-gradient(ellipse 60% 60% at 80% 50%,rgba(45,156,124,.10) 0%,transparent 70%),
             radial-gradient(ellipse 40% 40% at 20% 80%,rgba(79,122,59,.08) 0%,transparent 70%);
}
.page-hero::after{
  content:'';position:absolute;inset:0;pointer-events:none;
  background-image:linear-gradient(rgba(45,156,124,.04) 1px,transparent 1px),
                   linear-gradient(90deg,rgba(45,156,124,.04) 1px,transparent 1px);
  background-size:48px 48px;
}
/* floating particles */
.particle{
  position:absolute;border-radius:50%;pointer-events:none;
  background:radial-gradient(circle,rgba(75,192,160,.35),transparent);
  animation:float-p var(--d,8s) ease-in-out infinite;
}
@keyframes float-p{0%,100%{transform:translateY(0) scale(1);opacity:.5}50%{transform:translateY(var(--ty,-30px)) scale(1.2);opacity:.9}}

.hero-inner{max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;gap:3rem;position:relative;z-index:2}
.hero-copy{flex:1;max-width:640px}
.hero-badge{
  display:inline-flex;align-items:center;gap:8px;margin-bottom:22px;
  background:rgba(45,156,124,.12);border:1px solid rgba(45,156,124,.3);
  border-radius:40px;padding:6px 18px;
  font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--teal-l);
}
.hero-badge span{width:7px;height:7px;border-radius:50%;background:var(--teal-l);animation:pulse-dot 2s infinite}
@keyframes pulse-dot{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(1.5)}}
.hero-h1{font-family:'Syne',sans-serif;font-size:clamp(34px,5vw,62px);font-weight:800;color:#fff;line-height:1.1;letter-spacing:-.02em;margin-bottom:20px}
.hero-h1 em{font-style:normal;color:var(--teal-l)}
.hero-h1 .line2{display:block;color:var(--olive-l);font-size:.75em}
.hero-p{font-size:clamp(13px,1.8vw,15.5px);color:#cbdcd9;line-height:1.65;max-width:500px;margin-bottom:32px}
.hero-actions{display:flex;gap:14px;flex-wrap:wrap}
.btn-primary{
  padding:13px 30px;background:var(--teal);color:#fff;border:none;
  border-radius:50px;font-size:13px;font-weight:700;letter-spacing:.06em;
  text-transform:uppercase;cursor:pointer;transition:all .25s;text-decoration:none;
  display:inline-flex;align-items:center;gap:8px;
  box-shadow:0 8px 24px rgba(45,156,124,.35);
}
.btn-primary:hover{background:var(--teal-l);transform:translateY(-2px);box-shadow:0 14px 32px rgba(45,156,124,.4)}
.btn-outline{
  padding:13px 28px;background:transparent;color:var(--white);
  border:1px solid rgba(255,255,255,.22);border-radius:50px;
  font-size:13px;font-weight:600;cursor:pointer;transition:all .25s;text-decoration:none;
  display:inline-flex;align-items:center;gap:8px;
}
.btn-outline:hover{border-color:var(--teal-l);color:var(--teal-l);background:rgba(45,156,124,.07)}

/* stat mosaic */
.hero-mosaic{flex-shrink:0;display:grid;grid-template-columns:1fr 1fr;gap:14px;width:clamp(260px,32vw,340px)}
.stat-card{
  background:rgba(18,28,32,.85);border:1px solid rgba(45,156,124,.25);
  border-radius:20px;padding:22px 18px;text-align:center;
  backdrop-filter:blur(6px);transition:all .3s;
}
.stat-card:hover{border-color:var(--teal);transform:translateY(-5px);box-shadow:0 18px 36px rgba(45,156,124,.22)}
.stat-card.wide{grid-column:1/-1;display:flex;align-items:center;gap:16px;text-align:left;padding:18px 24px}
.stat-num{font-family:'Syne',sans-serif;font-size:32px;font-weight:800;color:var(--teal-l);line-height:1}
.stat-label{font-size:11px;color:var(--muted);font-weight:500;letter-spacing:.04em;margin-top:5px}
.stat-icon{font-size:28px}

@media(max-width:900px){
  .page-hero{padding:80px 1.8rem 50px}
  .hero-inner{flex-direction:column}
  .hero-copy{max-width:100%}
  .hero-mosaic{width:100%;max-width:420px;margin:0 auto}
}

/* =========================================================
   TICKER STRIP
   ========================================================= */
.ticker-strip{
  background:#080c0c;border-top:1px solid var(--border);border-bottom:1px solid var(--border);
  padding:14px 0;overflow:hidden;position:relative;
}
.ticker-strip::before,.ticker-strip::after{
  content:'';position:absolute;top:0;bottom:0;width:80px;z-index:2;pointer-events:none;
}
.ticker-strip::before{left:0;background:linear-gradient(90deg,#080c0c,transparent)}
.ticker-strip::after{right:0;background:linear-gradient(-90deg,#080c0c,transparent)}
.ticker-track{display:flex;gap:0;animation:ticker 28s linear infinite;width:max-content}
.ticker-track:hover{animation-play-state:paused}
.ticker-item{
  display:inline-flex;align-items:center;gap:10px;padding:0 32px;
  font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--teal-l);
  white-space:nowrap;
}
.ticker-item::before{content:'⚡';color:var(--olive-l);font-size:11px}
@keyframes ticker{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* =========================================================
   IMAGE SHOWCASE SECTION
   ========================================================= */
.showcase-section{
  background:linear-gradient(160deg,#090d10 0%,#0b1a16 55%,#091210 100%);
  border-bottom:1px solid var(--border);
  padding:clamp(70px,9vw,110px) clamp(24px,5vw,80px);
  position:relative;overflow:hidden;
}
.showcase-section::before{
  content:'';position:absolute;inset:0;pointer-events:none;
  background:radial-gradient(ellipse 55% 70% at 72% 50%,rgba(45,156,124,.10) 0%,transparent 70%),
             radial-gradient(ellipse 35% 50% at 15% 30%,rgba(79,122,59,.07) 0%,transparent 70%);
}
.showcase-inner{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1.1fr;gap:72px;align-items:center;position:relative;z-index:2}
@media(max-width:960px){.showcase-inner{grid-template-columns:1fr;gap:48px}}

.showcase-left{}
.section-label{
  display:inline-flex;align-items:center;gap:8px;
  font-size:11px;font-weight:700;color:var(--teal-l);letter-spacing:.12em;text-transform:uppercase;margin-bottom:14px;
}
.section-label::before{content:'';width:28px;height:2px;background:var(--teal-l)}
.section-title{font-family:'Syne',sans-serif;font-size:clamp(28px,4vw,44px);font-weight:800;color:#fff;letter-spacing:-.02em;margin-bottom:14px;line-height:1.18}
.section-sub{font-size:15px;color:#b8cfca;max-width:560px;margin-bottom:32px;line-height:1.65}

.svc-chip-list{display:flex;flex-direction:column;gap:10px;margin-bottom:32px}
.svc-chip{
  display:flex;align-items:center;gap:12px;
  padding:11px 18px;border-radius:14px;
  background:rgba(45,156,124,.06);border:1px solid rgba(45,156,124,.18);
  font-size:13px;font-weight:600;color:#d4eee9;
  transition:all .22s;cursor:default;
}
.svc-chip:hover{background:rgba(45,156,124,.14);border-color:var(--teal);transform:translateX(6px)}
.chip-icon{font-size:17px;flex-shrink:0}
.chip-dot{width:6px;height:6px;border-radius:50%;background:var(--teal-l);flex-shrink:0}

.trust-row{display:flex;gap:20px;flex-wrap:wrap;align-items:center}
.tr-item{font-size:11px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:var(--olive-l);display:flex;align-items:center;gap:5px}
.tr-item::before{content:'✦'}

/* image right */
.showcase-right{position:relative}
.img-frame{position:relative;border-radius:28px;overflow:visible}
.img-glow{
  position:absolute;inset:-3px;border-radius:30px;
  background:linear-gradient(135deg,rgba(45,156,124,.5),rgba(79,122,59,.25),rgba(45,156,124,.5));
  filter:blur(20px);opacity:.55;z-index:0;
  animation:glow-pulse 3.5s ease-in-out infinite;
}
@keyframes glow-pulse{0%,100%{opacity:.45}50%{opacity:.75}}
.showcase-img{
  position:relative;z-index:1;width:100%;border-radius:24px;display:block;
  border:1px solid rgba(45,156,124,.4);
  box-shadow:0 36px 72px rgba(0,0,0,.55),0 0 0 1px rgba(45,156,124,.12);
  transition:transform .45s ease,box-shadow .45s ease;
}
.img-frame:hover .showcase-img{transform:scale(1.018);box-shadow:0 48px 90px rgba(0,0,0,.6),0 0 50px rgba(45,156,124,.22)}
.floating-badge{
  position:absolute;z-index:3;
  background:rgba(10,16,18,.94);backdrop-filter:blur(10px);
  border:1px solid rgba(45,156,124,.45);border-radius:50px;
  padding:9px 18px;display:flex;align-items:center;gap:9px;
  font-size:11px;font-weight:700;color:var(--teal-l);letter-spacing:.07em;text-transform:uppercase;
  box-shadow:0 10px 24px rgba(0,0,0,.35);
}
.fb-tl{top:-16px;left:22px;animation:float-badge 3.5s ease-in-out infinite}
.fb-br{bottom:-16px;right:22px;animation:float-badge 3.5s ease-in-out infinite;animation-delay:1.8s}
@keyframes float-badge{0%,100%{transform:translateY(0)}50%{transform:translateY(-7px)}}
.fb-icon{font-size:15px}

/* corner accent lines */
.img-frame::before,.img-frame::after{
  content:'';position:absolute;z-index:4;pointer-events:none;
}
.img-frame::before{top:-1px;left:-1px;width:40px;height:40px;border-top:2px solid var(--teal-l);border-left:2px solid var(--teal-l);border-radius:12px 0 0 0}
.img-frame::after{bottom:-1px;right:-1px;width:40px;height:40px;border-bottom:2px solid var(--olive-l);border-right:2px solid var(--olive-l);border-radius:0 0 12px 0}

/* =========================================================
   SERVICES GRID SECTION
   ========================================================= */
.services-section{
  background:#0c1215;
  padding:clamp(70px,9vw,110px) clamp(24px,5vw,80px);
  border-bottom:1px solid var(--border);
}
.svc-section-inner{max-width:1200px;margin:0 auto}
.svc-header{display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:24px;margin-bottom:56px}
.svc-header-left{}
.svc-count-badge{
  display:inline-flex;align-items:center;gap:8px;
  background:rgba(79,122,59,.15);border:1px solid rgba(79,122,59,.35);
  border-radius:40px;padding:5px 14px;margin-top:10px;
  font-size:11px;font-weight:700;color:var(--olive-l);letter-spacing:.1em;text-transform:uppercase;
}

/* FEATURED BIG CARD */
.featured-card{
  display:grid;grid-template-columns:1.1fr 1fr;gap:0;
  background:linear-gradient(135deg,rgba(18,32,38,.98),rgba(10,20,24,.98));
  border:1px solid rgba(45,156,124,.38);border-radius:28px;
  overflow:hidden;margin-bottom:28px;
  box-shadow:0 20px 50px rgba(0,0,0,.35);
  transition:all .4s cubic-bezier(.2,.9,.4,1.1);
}
.featured-card:hover{transform:translateY(-6px);border-color:var(--teal);box-shadow:0 40px 80px rgba(45,156,124,.25)}
.fc-body{padding:40px 44px;display:flex;flex-direction:column;justify-content:center}
.fc-num{font-family:'Syne',sans-serif;font-size:11px;font-weight:700;color:rgba(75,192,160,.4);letter-spacing:.15em;margin-bottom:10px}
.fc-tag{display:inline-flex;align-items:center;gap:6px;background:rgba(45,156,124,.15);border:1px solid rgba(45,156,124,.3);border-radius:20px;padding:4px 12px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--teal-l);margin-bottom:18px;width:fit-content}
.fc-body h2{font-family:'Syne',sans-serif;font-size:clamp(22px,2.8vw,30px);font-weight:800;color:#f0f9f6;margin-bottom:14px;line-height:1.2}
.fc-body p{font-size:14px;color:#cbdcd9;line-height:1.65;margin-bottom:22px}
.fc-bullets{list-style:none;display:flex;flex-direction:column;gap:8px;margin-bottom:28px}
.fc-bullets li{display:flex;align-items:center;gap:10px;font-size:13px;color:var(--muted)}
.fc-bullets li::before{content:'';width:6px;height:6px;border-radius:50%;background:linear-gradient(135deg,var(--teal-l),var(--olive-l));flex-shrink:0}
.fc-cta{display:inline-flex;align-items:center;gap:8px;padding:11px 26px;background:var(--teal);color:#fff;border-radius:50px;font-size:12px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;text-decoration:none;transition:all .25s;width:fit-content;border:none;cursor:pointer}
.fc-cta:hover{background:var(--teal-l);transform:translateY(-1px)}
.fc-visual{
  background:linear-gradient(135deg,rgba(45,156,124,.12),rgba(79,122,59,.08));
  border-left:1px solid rgba(45,156,124,.2);
  display:flex;align-items:center;justify-content:center;
  font-size:90px;position:relative;overflow:hidden;min-height:300px;
}
.fc-visual::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse 60% 60% at 50% 50%,rgba(45,156,124,.15),transparent);
}
.fc-visual-icon{position:relative;z-index:1;filter:drop-shadow(0 8px 24px rgba(45,156,124,.4));animation:icon-float 4s ease-in-out infinite}
@keyframes icon-float{0%,100%{transform:translateY(0) scale(1)}50%{transform:translateY(-12px) scale(1.05)}}

@media(max-width:860px){.featured-card{grid-template-columns:1fr}.fc-visual{min-height:160px;font-size:60px}.fc-body{padding:28px}}

/* MAIN GRID */
.svc-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-bottom:28px}
@media(max-width:1024px){.svc-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:600px){.svc-grid{grid-template-columns:1fr}}

.svc-card{
  background:rgba(16,24,28,.88);border:1px solid rgba(45,156,124,.2);
  border-radius:24px;padding:30px 26px;position:relative;overflow:hidden;
  transition:all .35s cubic-bezier(.2,.9,.4,1.1);
}
.svc-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,transparent,var(--teal),transparent);opacity:0;transition:opacity .3s}
.svc-card:hover{transform:translateY(-10px) scale(1.015);border-color:var(--teal);background:rgba(20,32,36,.96);box-shadow:0 30px 56px rgba(45,156,124,.28)}
.svc-card:hover::before{opacity:1}
.card-num{position:absolute;top:18px;right:22px;font-family:'Syne',sans-serif;font-size:11px;font-weight:700;color:rgba(75,192,160,.3);letter-spacing:.12em}
.card-tag{display:inline-flex;align-items:center;gap:5px;background:rgba(45,156,124,.1);border:1px solid rgba(45,156,124,.22);border-radius:20px;padding:3px 10px;font-size:9.5px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--teal-l);margin-bottom:14px;width:fit-content}
.card-icon{font-size:38px;margin-bottom:16px;display:block;filter:drop-shadow(0 4px 10px rgba(0,0,0,.3))}
.svc-card h3{font-family:'Syne',sans-serif;font-size:18px;font-weight:700;color:#f0f9f6;margin-bottom:10px;letter-spacing:-.1px;line-height:1.25}
.svc-card p{font-size:13px;color:#cbdcd9;line-height:1.6}
.card-bullets{margin-top:14px;list-style:none;display:flex;flex-direction:column;gap:6px}
.card-bullets li{font-size:12px;color:var(--muted);display:flex;align-items:center;gap:8px}
.card-bullets li::before{content:'';width:5px;height:5px;border-radius:50%;background:var(--teal-l);flex-shrink:0}
.card-link{margin-top:18px;display:inline-flex;align-items:center;gap:5px;font-size:11.5px;font-weight:700;color:var(--teal-l);text-transform:uppercase;letter-spacing:.08em;text-decoration:none;transition:gap .2s,opacity .2s}
.card-link:hover{gap:10px;opacity:.85}

/* SMALL GRID */
.svc-grid-sm{display:grid;grid-template-columns:repeat(4,1fr);gap:20px}
@media(max-width:900px){.svc-grid-sm{grid-template-columns:repeat(2,1fr)}}
@media(max-width:480px){.svc-grid-sm{grid-template-columns:1fr}}
.svc-card-sm{
  background:rgba(14,20,24,.88);border:1px solid rgba(45,156,124,.16);
  border-radius:20px;padding:24px 20px;transition:all .3s;position:relative;
}
.svc-card-sm:hover{transform:translateY(-6px);border-color:var(--teal);box-shadow:0 20px 40px rgba(45,156,124,.2)}
.svc-card-sm .card-icon{font-size:30px;margin-bottom:12px}
.svc-card-sm h3{font-size:14px;font-weight:700;color:#f0f9f6;margin-bottom:8px}
.svc-card-sm p{font-size:12px;color:#cbdcd9;line-height:1.55}

/* =========================================================
   TRUSTED PARTNER SECTION
   ========================================================= */
.partner-section{
  background:#090c0e;
  padding:clamp(70px,9vw,110px) clamp(24px,5vw,80px);
  border-bottom:1px solid var(--border);
}
.partner-inner{max-width:1200px;margin:0 auto}
.partner-grid{display:grid;grid-template-columns:1fr 1.15fr;gap:64px;align-items:center}
@media(max-width:900px){.partner-grid{grid-template-columns:1fr;gap:48px}}

.partner-visual-box{
  background:linear-gradient(135deg,rgba(18,30,36,.96),rgba(10,18,22,.96));
  border:1px solid rgba(45,156,124,.3);border-radius:28px;padding:36px;
}
.pvb-header{display:flex;align-items:center;gap:16px;margin-bottom:28px}
.atp-logo-box{width:60px;height:60px;border-radius:16px;background:linear-gradient(135deg,#4f7a3b,#2d9c7c);display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-size:18px;font-weight:800;color:#fff}
.pvb-title{font-family:'Syne',sans-serif;font-size:17px;font-weight:700;color:#fff}
.pvb-sub{font-size:11px;color:var(--teal-l);font-style:italic;margin-top:3px}
.client-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}
.client-chip{
  background:rgba(45,156,124,.07);border:1px solid rgba(45,156,124,.18);
  border-radius:12px;padding:10px 14px;font-size:12px;font-weight:600;
  color:#d4eee9;display:flex;align-items:center;gap:8px;transition:all .22s;
}
.client-chip:hover{background:rgba(45,156,124,.16);border-color:var(--teal);transform:translateY(-2px)}
.client-chip::before{content:'⚡';font-size:10px;color:var(--olive-l)}

.partner-copy{}
.why-list{display:flex;flex-direction:column;gap:16px;margin-bottom:32px}
.why-item{
  display:flex;gap:16px;align-items:flex-start;
  padding:16px 20px;border-radius:16px;
  border:1px solid rgba(45,156,124,.14);background:rgba(45,156,124,.03);
  transition:all .25s;
}
.why-item:hover{border-color:var(--teal);background:rgba(45,156,124,.08);transform:translateX(5px)}
.why-icon{font-size:22px;flex-shrink:0;margin-top:2px}
.why-text strong{font-size:13px;font-weight:700;color:#f0f9f6;display:block;margin-bottom:4px}
.why-text span{font-size:12px;color:var(--muted);line-height:1.55}

/* =========================================================
   APPROACH / PROCESS
   ========================================================= */
.approach-section{
  background:linear-gradient(180deg,#0c1215,#0b0e0e);
  border-bottom:1px solid var(--border);
  padding:clamp(70px,9vw,110px) clamp(24px,5vw,80px);
}
.approach-inner{max-width:1200px;margin:0 auto}
.approach-head{text-align:center;margin-bottom:64px}
.approach-head .section-label{justify-content:center}
.approach-head .section-label::before{display:none}
.approach-head .section-title{margin-bottom:12px}
.approach-head .section-sub{margin:0 auto;text-align:center}

.process-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:0;position:relative}
.process-grid::before{content:'';position:absolute;top:36px;left:12%;right:12%;height:1px;background:linear-gradient(90deg,transparent,var(--teal) 30%,var(--olive-l) 70%,transparent);z-index:0}
.process-step{position:relative;z-index:1;text-align:center;padding:0 16px}
.ps-num{
  width:72px;height:72px;border-radius:50%;margin:0 auto 24px;
  background:linear-gradient(135deg,var(--teal-d),var(--teal));
  display:flex;align-items:center;justify-content:center;
  font-family:'Syne',sans-serif;font-size:22px;font-weight:800;color:#fff;
  box-shadow:0 8px 24px rgba(45,156,124,.4);
  transition:all .35s;border:3px solid rgba(45,156,124,.25);
}
.process-step:hover .ps-num{transform:scale(1.1) rotate(5deg);box-shadow:0 14px 32px rgba(45,156,124,.55)}
.ps-icon{font-size:24px;display:block;margin-bottom:14px}
.process-step h4{font-family:'Syne',sans-serif;font-size:15px;font-weight:700;color:#f0f9f6;margin-bottom:8px}
.process-step p{font-size:12.5px;color:var(--muted);line-height:1.55}
@media(max-width:720px){.process-grid{grid-template-columns:repeat(2,1fr);gap:40px}.process-grid::before{display:none}}
@media(max-width:420px){.process-grid{grid-template-columns:1fr}}

/* =========================================================
   STATS BAND
   ========================================================= */
.stats-band{
  background:linear-gradient(90deg,#0a1a14,#091510,#0a1a14);
  border-top:1px solid rgba(45,156,124,.3);border-bottom:1px solid rgba(45,156,124,.3);
  padding:clamp(40px,5vw,60px) clamp(24px,5vw,80px);
}
.stats-band-inner{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:20px;text-align:center}
@media(max-width:700px){.stats-band-inner{grid-template-columns:repeat(2,1fr)}}
.big-stat{padding:28px 16px;border-radius:20px;border:1px solid rgba(45,156,124,.18);background:rgba(45,156,124,.04);transition:all .3s}
.big-stat:hover{border-color:var(--teal);background:rgba(45,156,124,.09);transform:translateY(-4px)}
.bs-num{font-family:'Syne',sans-serif;font-size:clamp(32px,4vw,48px);font-weight:800;color:var(--teal-l);line-height:1;margin-bottom:6px}
.bs-label{font-size:12px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.08em}

/* =========================================================
   CTA SECTION
   ========================================================= */
.cta-section{
  background:linear-gradient(135deg,#0d2820 0%,#0a1b15 50%,#0b2218 100%);
  border-bottom:1px solid rgba(45,156,124,.3);
  padding:clamp(60px,8vw,100px) clamp(24px,5vw,80px);
  position:relative;overflow:hidden;
}
.cta-section::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 55% 80% at 50% 50%,rgba(45,156,124,.13),transparent);pointer-events:none}
.cta-section::after{content:'';position:absolute;inset:0;background-image:linear-gradient(rgba(45,156,124,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(45,156,124,.03) 1px,transparent 1px);background-size:40px 40px;pointer-events:none}
.cta-inner{max-width:860px;margin:0 auto;text-align:center;position:relative;z-index:2}
.cta-inner h2{font-family:'Syne',sans-serif;font-size:clamp(28px,4.5vw,48px);font-weight:800;color:#fff;margin-bottom:18px;line-height:1.15}
.cta-inner h2 em{font-style:normal;color:var(--teal-l)}
.cta-inner p{font-size:15px;color:#b8cfca;margin-bottom:36px;line-height:1.65}
.cta-btns{display:flex;gap:16px;justify-content:center;flex-wrap:wrap}
.cta-contact-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:40px;max-width:700px;margin-left:auto;margin-right:auto}
@media(max-width:600px){.cta-contact-grid{grid-template-columns:1fr}}
.contact-card{background:rgba(18,28,32,.8);border:1px solid rgba(45,156,124,.22);border-radius:16px;padding:20px;transition:all .25s}
.contact-card:hover{border-color:var(--teal);background:rgba(22,36,42,.95);transform:translateY(-3px)}
.cc-icon{font-size:24px;margin-bottom:8px}
.cc-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--teal-l);margin-bottom:4px}
.cc-val{font-size:12px;color:#d4eee9;font-weight:500}

/* =========================================================
   FOOTER
   ========================================================= */
.main-footer{background:#050808;border-top:1px solid var(--border);padding:2.5rem 1.5rem 2rem;color:#b9cdc8;font-size:12px}
.footer-inner{max-width:1200px;margin:0 auto;display:flex;flex-wrap:wrap;justify-content:space-between;align-items:center;gap:16px}
.footer-brand{display:flex;align-items:center;gap:10px}
.footer-brand-txt .brand{font-family:'Syne',sans-serif;font-size:16px;font-weight:700;color:#fff;letter-spacing:2px;display:block}
.footer-brand-txt .sub{font-size:9px;color:var(--olive-l);text-transform:uppercase;letter-spacing:2px}
.footer-links{display:flex;gap:24px;flex-wrap:wrap}
.footer-links a{color:var(--teal-l);text-decoration:none;font-weight:500;transition:color .2s}
.footer-links a:hover{color:var(--white)}
.footer-copy{width:100%;text-align:center;padding-top:20px;border-top:1px solid rgba(79,122,59,.2);margin-top:16px;color:rgba(176,196,194,.5);font-size:11px}
@media(max-width:700px){.footer-inner{flex-direction:column;gap:16px;align-items:flex-start}}

/* =========================================================
   REVEAL ANIMATION
   ========================================================= */
.reveal{opacity:0;transform:translateY(32px);transition:opacity .65s ease,transform .65s ease}
.reveal.visible{opacity:1;transform:translateY(0)}
.reveal-delay-1{transition-delay:.1s}.reveal-delay-2{transition-delay:.2s}
.reveal-delay-3{transition-delay:.3s}.reveal-delay-4{transition-delay:.4s}
</style>
</head>
