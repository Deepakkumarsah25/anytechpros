 <link rel="stylesheet" href="/css/service/service.css">
</head>
<body>
  <%- include("../common/header.ejs") %>
  <main>
    <!-- Hero section with container inside hero-wrapper (fixed) -->
    <div class="hero-wrapper">
      <div class="container">
        <div class="hero-grid">
          <div class="hero-content reveal">
            <div class="hero-badge">FULL-SPECTRUM SOLUTIONS</div>
            <h1>Our <span>Services</span><br>Built for Impact.</h1>
            <p>From government advisory to AI automation — AnyTechPros delivers integrated, end-to-end technology solutions for enterprises, public sector bodies, and high-growth startups.</p>
            <div class="hero-buttons">
              <a href="#services-core" class="btn-primary">Explore Services ↓</a>
              <a href="/contect" class="btn-outline">Talk to Us →</a>
            </div>
          </div>
          <div class="hero-cards-grid reveal reveal-delay-1">
            <div class="hero-feature-card"><div class="card-icon">🏛️</div><h4>Govt. Advisory</h4><p>PMU, policy, compliance</p></div>
            <div class="hero-feature-card"><div class="card-icon">⚙️</div><h4>Tech Delivery</h4><p>AI, cloud, automation</p></div>
            <div class="hero-feature-card"><div class="card-icon">🔒</div><h4>Cybersecurity</h4><p>Audits, SOC, compliance</p></div>
            <div class="hero-feature-card"><div class="card-icon">📡</div><h4>Telecom & Infra</h4><p>Network, OSS/BSS</p></div>
          </div>
        </div>
      </div>
    </div>

    <!-- 6 CORE SERVICE GROUPS (refined per requirement) -->
    <section id="services-core">
      <div class="container">
        <div class="reveal">
          <span class="section-badge">Core Solutions</span>
          <h2>Integrated service clusters</h2>
          <p class="section-subhead">Purpose‑built for government, enterprise & infrastructure challenges</p>
        </div>
        <div class="services-grid">
          <!-- 1. Government Advisory & PMU Support -->
          <div class="service-card reveal">
            <div class="card-icon">🏛️</div>
            <h3>Government Advisory & PMU Support</h3>
            <div class="detail-row"><span class="detail-label">👥 For:</span><span class="detail-text">Ministries, State depts, PSUs, Smart City missions</span></div>
            <div class="detail-row"><span class="detail-label">⚠️ Problem:</span><span class="detail-text">Fragmented program management, delayed approvals, weak PMU structures</span></div>
            <div class="detail-row"><span class="detail-label">📦 Includes:</span><span class="detail-text">PMU setup, governance frameworks, policy drafting, MIS dashboards, stakeholder coordination</span></div>
            <div class="detail-row"><span class="detail-label">🤝 Engagement:</span><span class="detail-text">Advisory Retainer / PMU Support</span></div>
            <a href="#contact-cta" class="card-cta">Discuss Your Requirement →</a>
          </div>
          <!-- 2. Contracting, Documentation & Compliance -->
          <div class="service-card reveal">
            <div class="card-icon">📜</div>
            <h3>Contracting, Documentation & Compliance</h3>
            <div class="detail-row"><span class="detail-label">👥 For:</span><span class="detail-text">Procurement heads, legal teams, Govt contractors</span></div>
            <div class="detail-row"><span class="detail-label">⚠️ Problem:</span><span class="detail-text">Non-compliant RFPs, contractual disputes, audit risks</span></div>
            <div class="detail-row"><span class="detail-label">📦 Includes:</span><span class="detail-text">RFP/RFQ/EOI drafting, GeM support, contract lifecycle mgmt, compliance audits, risk assessment</span></div>
            <div class="detail-row"><span class="detail-label">🤝 Engagement:</span><span class="detail-text">Project-Based Delivery / Retainer</span></div>
            <a href="#contact-cta" class="card-cta">Discuss Your Requirement →</a>
          </div>
          <!-- 3. Technology Design & Delivery -->
          <div class="service-card reveal">
            <div class="card-icon">⚙️</div>
            <h3>Technology Design & Delivery</h3>
            <div class="detail-row"><span class="detail-label">👥 For:</span><span class="detail-text">CTOs, digital transformation leads, enterprises</span></div>
            <div class="detail-row"><span class="detail-label">⚠️ Problem:</span><span class="detail-text">Legacy systems, slow delivery, vendor lock-in</span></div>
            <div class="detail-row"><span class="detail-label">📦 Includes:</span><span class="detail-text">Custom software, cloud migration, API integration, agile delivery, QA automation, DevOps</span></div>
            <div class="detail-row"><span class="detail-label">🤝 Engagement:</span><span class="detail-text">Project-Based Delivery / Implementation Support</span></div>
            <a href="#contact-cta" class="card-cta">Discuss Your Requirement →</a>
          </div>
          <!-- 4. Telecom & Infrastructure Consulting -->
          <div class="service-card reveal">
            <div class="card-icon">📡</div>
            <h3>Telecom & Infrastructure Consulting</h3>
            <div class="detail-row"><span class="detail-label">👥 For:</span><span class="detail-text">Telecom operators, DoT, BharatNet, Infrastructure SPVs</span></div>
            <div class="detail-row"><span class="detail-label">⚠️ Problem:</span><span class="detail-text">Network inefficiencies, high OPEX, regulatory non-alignment</span></div>
            <div class="detail-row"><span class="detail-label">📦 Includes:</span><span class="detail-text">Network architecture, OSS/BSS transformation, fiber rollout planning, spectrum advisory, TRAI compliance</span></div>
            <div class="detail-row"><span class="detail-label">🤝 Engagement:</span><span class="detail-text">Advisory Retainer / Project Delivery</span></div>
            <a href="#contact-cta" class="card-cta">Discuss Your Requirement →</a>
          </div>
          <!-- 5. Cybersecurity, Analytics & Automation -->
          <div class="service-card reveal">
            <div class="card-icon">🔒</div>
            <h3>Cybersecurity, Analytics & Automation</h3>
            <div class="detail-row"><span class="detail-label">👥 For:</span><span class="detail-text">CISOs, data officers, compliance & IT teams</span></div>
            <div class="detail-row"><span class="detail-label">⚠️ Problem:</span><span class="detail-text">Cyber threats, manual processes, lack of real-time intelligence</span></div>
            <div class="detail-row"><span class="detail-label">📦 Includes:</span><span class="detail-text">VAPT, SOC implementation, security audits, RPA/AI automation, data analytics dashboards, CERT-In readiness</span></div>
            <div class="detail-row"><span class="detail-label">🤝 Engagement:</span><span class="detail-text">Specialist Staffing / Project-Based</span></div>
            <a href="#contact-cta" class="card-cta">Discuss Your Requirement →</a>
          </div>
          <!-- 6. Workforce & Project Support -->
          <div class="service-card reveal">
            <div class="card-icon">👥</div>
            <h3>Workforce & Project Support</h3>
            <div class="detail-row"><span class="detail-label">👥 For:</span><span class="detail-text">HR heads, project directors, government recruitment cells</span></div>
            <div class="detail-row"><span class="detail-label">⚠️ Problem:</span><span class="detail-text">Talent shortage, skill gaps, high attrition, staffing compliance</span></div>
            <div class="detail-row"><span class="detail-label">📦 Includes:</span><span class="detail-text">Contract staffing, permanent recruitment, project-based augmentation, payroll mgmt, L&D programs</span></div>
            <div class="detail-row"><span class="detail-label">🤝 Engagement:</span><span class="detail-text">Specialist Staffing / Implementation Support</span></div>
            <a href="#contact-cta" class="card-cta">Discuss Your Requirement →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Engagement models section -->
    <section id="engagement">
      <div class="container">
        <div class="reveal">
          <span class="section-badge">flexible collaboration</span>
          <h2>Engagement models</h2>
          <p class="section-subhead">Choose the way we work together — tailored to your risk, budget, and timeline.</p>
        </div>
        <div class="engagement-grid">
          <div class="engagement-card reveal"><span class="card-icon">📋</span><strong>Advisory Retainer</strong><p>Strategic guidance, on‑tap expertise, monthly governance reviews</p></div>
          <div class="engagement-card reveal"><span class="card-icon">🚀</span><strong>Project-Based Delivery</strong><p>Fixed-scope, milestone-driven execution with clear deliverables</p></div>
          <div class="engagement-card reveal"><span class="card-icon">📊</span><strong>PMU / Monitoring Support</strong><p>Embedded PMU, real-time dashboards, risk & compliance monitoring</p></div>
          <div class="engagement-card reveal"><span class="card-icon">🎯</span><strong>Specialist Staffing</strong><p>Rapid deployment of niche talent for cybersecurity, tech, and project roles</p></div>
          <div class="engagement-card reveal"><span class="card-icon">🔄</span><strong>Implementation Support</strong><p>Hands‑on execution, rollout assistance, post-deployment handholding</p></div>
        </div>
      </div>
    </section>

    <!-- MINI PROOF BLOCKS -->
    <section>
      <div class="container">
        <div class="reveal">
          <span class="section-badge">proof of impact</span>
          <h2>Where we deliver results</h2>
          <p class="section-subhead">Real‑world evidence of transformation across sectors</p>
        </div>
        <div class="proof-blocks">
          <div class="proof-item reveal"><h4>🏭 Sectors served</h4><ul><li>Government (Central/State)</li><li>Telecom & Infrastructure</li><li>Smart Cities & Urban Dev</li><li>Energy & Utilities</li><li>Defence & PSUs</li></ul></div>
          <div class="proof-item reveal"><h4>🔒 Anonymized examples</h4><ul><li>• State Transport Dept: reduced tender cycle by 40% via PMU support</li><li>• National Telco: ₹120 Cr OPEX saved through network automation</li><li>• Smart City Mission: deployed AI-based grievance redressal</li></ul></div>
          <div class="proof-item reveal"><h4>📄 Typical outputs</h4><ul><li>PMU governance playbooks</li><li>RFP / contract templates</li><li>Cybersecurity audit reports</li><li>Real‑time MIS dashboards</li><li>AI/automation workflows</li></ul></div>
          <div class="proof-item reveal"><h4>🧠 Relevant frameworks</h4><ul><li>PMP / PRINCE2, ITIL4</li><li>TOGAF, NIST CSF, ISO 27001</li><li>GeM, DGS&D, CVC guidelines</li><li>Digital India frameworks</li></ul></div>
        </div>
      </div>
    </section>

    <!-- ADDITIONAL ADVISORY SUPPORT (lower priority) -->
    <section id="advisory-support">
      <div class="container">
        <div class="advisory-support reveal">
          <span class="section-badge" style="background:rgba(107,140,66,0.2);">Additional Advisory Support</span>
          <h2 style="margin-bottom: 0.5rem;">Specialized Growth & Market Access</h2>
          <p style="color: var(--text-muted);">Complementary services for organizations seeking market traction and brand acceleration.</p>
          <div class="support-flex">
            <div class="support-card"><div class="card-icon">📈</div><h4>Digital Marketing</h4><p>Performance marketing, SEO, content strategy, lead generation, and brand positioning for B2B, B2G and enterprise segments.</p><ul class="list-inline"><li>SEO & Analytics</li><li>Paid campaigns</li><li>Social & content</li></ul></div>
            <div class="support-card"><div class="card-icon">🤝</div><h4>GTM & Business Matchmaking</h4><p>Market entry strategy, partner identification, channel ecosystem development, and opportunity mapping for government and private tenders.</p><ul class="list-inline"><li>Partner scouting</li><li>Bid advisory</li><li>GTM playbooks</li></ul></div>
          </div>
          <p class="pill-badge" style="display:inline-block; margin-top: 1rem; background:rgba(75,192,160,0.1); padding:0.2rem 0.7rem; border-radius:20px; font-size:0.7rem;">Ideal for startups, MNCs & enterprises expanding into India's public sector</p>
        </div>
      </div>
    </section>

    <!-- FINAL CTA: Speak with a Solutions Expert -->
    <section id="contact-cta">
      <div class="container">
        <div class="final-cta reveal">
          <span class="section-badge" style="background: rgba(75,192,160,0.2);">Let's talk</span>
          <h2 style="font-size: clamp(1.8rem, 5vw, 2.5rem);">Ready to accelerate your mission?</h2>
          <p style="max-width: 580px; margin: 0 auto; color: #d4ece7;">Discuss your unique requirements with a solutions expert. We’ll match you with the right engagement model and service cluster.</p>
          <a href="/contect" class="btn-expert" id="expertCtaBtn">🗣️ Speak with a Solutions Expert →</a>
          <div style="margin-top: 2rem; display: flex; gap: 1.5rem; justify-content: center; flex-wrap: wrap; font-size: 0.85rem;"><span>📧 experts@anytechpros.com</span><span>📞 +91 96256 51944</span></div>
        </div>
      </div>
    </section>
  </main>

  <%- include("../common/footer.ejs") %>

  <script>
    // reveal animations
    const reveals = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => { if (entry.isIntersecting) { entry.target.classList.add('visible'); observer.unobserve(entry.target); } });
    }, { threshold: 0.08 });
    reveals.forEach(el => observer.observe(el));

    // expert CTA alert
    
    // smooth scroll for all "Discuss Your Requirement" buttons
    document.querySelectorAll('.card-cta').forEach(btn => { btn.addEventListener('click', (e) => { e.preventDefault(); document.querySelector('#contact-cta')?.scrollIntoView({ behavior: 'smooth', block: 'center' }); }); });
    // initial visible check
    window.addEventListener('load', () => { reveals.forEach(el => { if (el.getBoundingClientRect().top < window.innerHeight - 100) el.classList.add('visible'); }); });
  </script>
</body>
</html>