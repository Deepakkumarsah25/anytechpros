      <h4>Why choose us</h4>
      <p>With 28+ years of combined government consulting experience, we ensure every document is audit‑ready, transparent, and aligned with the latest legal frameworks. Our deliverables reduce procurement cycles and mitigate contractual disputes.</p>`
    },
    "gtm": {
      title: "GTM Strategy & Business Matchmaking",
      badge: "Growth",
      description: `<p>We design data‑driven go‑to‑market strategies for enterprises and startups targeting government and B2G sectors. Our matchmaking engine connects you with the right partners, system integrators, and public sector stakeholders.</p>
      <h4>Capabilities</h4>
      <ul><li>Market segmentation &amp; opportunity mapping</li><li>Partner ecosystem development (SIs, OEMs, Govt bodies)</li><li>Revenue growth roadmaps &amp; pricing strategies</li><li>Bid‑ready positioning &amp; proposal support</li></ul>
      <h4>Impact</h4>
      <p>We have facilitated 50+ successful partnerships between technology providers and government departments across 15+ states.</p>`
    },
    "project-mgmt": {
      title: "End-to-End Project Management & Monitoring",
      badge: "Operations",
      description: `<p>Full lifecycle ownership for government and enterprise projects. We establish PMOs, implement real‑time monitoring dashboards, and ensure milestone adherence with risk mitigation.</p>
      <h4>Services include</h4>
      <ul><li>Agile &amp; waterfall delivery frameworks</li><li>PMO setup, governance &amp; capacity building</li><li>Live MIS, geospatial dashboards &amp; automated alerts</li><li>Quality assurance, vendor coordination &amp; reporting</li></ul>
      <h4>Track record</h4>
      <p>Managed 200+ projects for clients like Indian Railways, BSNL, and state IT departments with 96% client satisfaction.</p>`
    },
    "recruitment": {
      title: "Recruitment & Workforce Solutions",
      badge: "Talent",
      description: `<p>Strategic talent acquisition for IT, telecom, and government sectors. We provide bulk hiring, executive search, and HR consulting tailored to public sector compliance.</p>
      <h4>What we deliver</h4>
      <ul><li>IT &amp; tech talent sourcing (AI, cyber, cloud)</li><li>Government project manpower (contract &amp; permanent)</li><li>HR policy design &amp; compliance audits</li><li>Assessment centres &amp; onboarding automation</li></ul>
      <h4>Our edge</h4>
      <p>10+ years of Big Four consulting experience ensures we attract top talent while meeting stringent government norms.</p>`
    },
    "strategic-consulting": {
      title: "Strategic Consulting for Business Growth",
      badge: "Advisory",
      description: `<p>High‑impact advisory for policy execution, digital transformation, and organizational change. We bridge the gap between vision and measurable outcomes.</p>
      <h4>Focus areas</h4>
      <ul><li>Business transformation &amp; operating model design</li><li>Policy execution frameworks &amp; program governance</li><li>Digital maturity assessments &amp; roadmaps</li><li>Stakeholder alignment &amp; change management</li></ul>
      <h4>Results driven</h4>
      <p>Trusted by Big 6 firms and state governments to deliver transformation programs worth ₹500+ crore.</p>`
    },
    "digital-marketing": {
      title: "Digital Marketing & Brand Growth",
      badge: "Marketing",
      description: `<p>Data‑driven campaigns that build brand authority and generate leads in B2B, B2G, and enterprise segments. We combine creativity with performance analytics.</p>
      <h4>Services</h4>
      <ul><li>SEO &amp; content strategy (technical &amp; thought leadership)</li><li>Performance marketing (Google Ads, LinkedIn)</li><li>Brand identity, positioning &amp; messaging</li><li>Social media management &amp; reputation monitoring</li></ul>
      <h4>Why us</h4>
      <p>We understand government and enterprise buying cycles, delivering measurable ROI and pipeline growth.</p>`
    }
  };

  // Get modal elements
  const modal = document.getElementById('serviceModal');
  const modalContent = document.getElementById('modalContent');
  const closeModalBtn = document.querySelector('.modal-close');

  function openModal(serviceKey) {
    const data = serviceDetails[serviceKey];
    if (!data) return;
    modalContent.innerHTML = `
      <div class="badge">${data.badge}</div>
      <h3>${data.title}</h3>
      ${data.description}
    `;
    modal.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.classList.remove('active');
    document.body.style.overflow = '';
  }

  // Attach event listeners to all .card-link elements
  document.querySelectorAll('.card-link').forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const service = link.getAttribute('data-service');
      if (service) openModal(service);
    });
  });

  // Close modal on background click or close button
  closeModalBtn.addEventListener('click', closeModal);
  modal.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  // Reveal animation observer
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });
  reveals.forEach(el => observer.observe(el));
</script>
