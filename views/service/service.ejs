<script>
  // Detailed content for each service
  const serviceDetails = {
    "govt-drafting": {
      title: "Government Drafting & Contract Writing",
      badge: "Legal Tech",
      description: `<p>AnyTechPros provides end‑to‑end contract lifecycle management and legal drafting services tailored for government procurement, public‑private partnerships, and regulatory compliance. Our team brings deep expertise in GeM, DGS&D, and state procurement rules.</p>
