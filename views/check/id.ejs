<script>
let photoSrc = null;

// ── AUTO ID GENERATOR ──
function generateUniqueId() {
  const year = new Date().getFullYear();
  const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';
  let suffix = '';
  for (let i = 0; i < 6; i++) {
    suffix += chars.charAt(Math.floor(Math.random() * chars.length));
  }
  return `RID-${year}-${suffix}`;
}

function regenId() {
  const newId = generateUniqueId();
  document.getElementById('autoIdDisplay').textContent = newId;
  document.getElementById('f_id').value = newId;
}

// Generate ID on page load
window.addEventListener('DOMContentLoaded', () => {
  regenId();
});

function goTab(t) {
  document.getElementById('paneForm').classList.toggle('on', t==='form');
  document.getElementById('panePreview').classList.toggle('on', t==='preview');
  document.getElementById('tab1').classList.toggle('on', t==='form');
  document.getElementById('tab2').classList.toggle('on', t==='preview');
}

function loadPhoto(inp) {
  if (!inp.files[0]) return;
  const r = new FileReader();
  r.onload = e => {
    photoSrc = e.target.result;
    const img = document.getElementById('photoPreview');
    img.src = photoSrc; img.style.display = 'block';
    document.querySelector('.photoBox svg').style.display = 'none';
    document.querySelector('.photoBox span').style.display = 'none';
  };
  r.readAsDataURL(inp.files[0]);
}

function fmtDate(v) {
  if (!v) return '';
  const d = new Date(v);
  const dd = String(d.getDate()).padStart(2,'0');
  const mm = String(d.getMonth()+1).padStart(2,'0');
  return `${dd}-${mm}-${d.getFullYear()}`;
}

function cap(s) {
  return s.split(' ').map(w => w.charAt(0).toUpperCase()+w.slice(1).toLowerCase()).join(' ');
}

function generate() {
  const fn  = (document.getElementById('f_first').value || 'Name').toUpperCase();
  const ln  = (document.getElementById('f_last').value  || 'Kumar').toUpperCase();
  
  const roleEl = document.getElementById('f_role');
  const role = roleEl.value ? roleEl.value : 'MERN STACK DEVELOPER';
  
  const id  = document.getElementById('f_id').value || generateUniqueId();
  const em  = document.getElementById('f_email').value || 'xyz@gmail.com';
  const ph  = document.getElementById('f_phone').value || '6394213627';
  const jn  = fmtDate(document.getElementById('f_join').value)  || '02-12-2025';
  const ex  = fmtDate(document.getElementById('f_exp').value)   || '02-12-2026';
  const comp= document.getElementById('f_comp').value  || 'RRIDTECH.PVT.LTD BHOPAL';
  const tag = document.getElementById('f_tag').value   || 'TECHNOLOGY FOR TOMORROW';
  const web = document.getElementById('f_web').value   || 'www.ridtech.in';
  const cph = document.getElementById('f_cph').value   || '+91 1234567890';
  const cem = document.getElementById('f_cem').value   || 'info@ridtechbhopal.com';
  const addr= document.getElementById('f_addr').value  || 'Bhopal, Madhya Pradesh, India';
  const t1  = document.getElementById('f_t1').value;
  const t2  = document.getElementById('f_t2').value;

  // Company name split for styling
  const parts = comp.trim().split(' ');
  const c1 = parts.slice(0,-1).join(' ') || comp;
  const c2 = parts[parts.length-1] || '';
  document.getElementById('cName').innerHTML = `${c1} <em>${c2}</em>`;
  document.getElementById('cTagline').textContent = tag;

  // Front
  document.getElementById('cFirstName').childNodes[0].nodeValue = fn + ' ';
  document.getElementById('cLastName').textContent = ln;
  document.getElementById('cRole').textContent = role;
  document.getElementById('cIdNo').textContent   = id;
  document.getElementById('cEmail').textContent  = em;
  document.getElementById('cPhone').textContent  = ph;
  document.getElementById('cJoin').textContent   = jn;
  document.getElementById('cExp').textContent    = ex;
  document.getElementById('cWeb').textContent    = web;

  // Photo
  const ring = document.getElementById('photoRing');
  if (photoSrc) {
    ring.innerHTML = `<img src="${photoSrc}">`;
  } else {
    ring.innerHTML = `<div class="noPhoto">👤</div>`;
  }

  // Back
  document.getElementById('bT1').textContent   = t1;
  document.getElementById('bT2').textContent   = t2;
  document.getElementById('bComp').textContent = comp;
  document.getElementById('bAddr').textContent = addr;
  document.getElementById('bCph').textContent  = cph;
  document.getElementById('bWeb').textContent  = web;
  document.getElementById('bCem').textContent  = cem;
  document.getElementById('bSig').textContent  = cap(fn) + ' ' + cap(ln);

  // QR
  const qd = document.getElementById('qrCanvas');
  qd.innerHTML = '';
  new QRCode(qd, {
    text: `Name:${fn} ${ln}\nID:${id}\nRole:${role}\nPhone:${ph}\nEmail:${em}\nWebsite:${web}`,
    width:70, height:70,
    colorDark:'#1C2030', colorLight:'#ffffff',
    correctLevel: QRCode.CorrectLevel.M
  });

  goTab('preview');
}

async function dl(elId, fname) {
  const el = document.getElementById(elId);
  try {
    const dataUrl = await htmlToImage.toPng(el, {
      cacheBust: true,
      pixelRatio: 3,
      backgroundColor: null,
      style: { transform: 'scale(1)', transformOrigin: 'top left' }
    });
    const a = document.createElement('a');
    a.download = fname;
    a.href = dataUrl;
    a.click();
  } catch (err) {
    console.error("Download error:", err);
    alert("Download failed! Check console.");
  }
}

async function dlBoth() {
  const front = document.getElementById('cardFront');
  const back  = document.getElementById('cardBack');
  try {
    const frontImg = await htmlToImage.toPng(front, { cacheBust: true, pixelRatio: 3, backgroundColor: null });
    const backImg  = await htmlToImage.toPng(back,  { cacheBust: true, pixelRatio: 3, backgroundColor: null });
    function download(dataUrl, filename) {
      const a = document.createElement('a');
      a.href = dataUrl; a.download = filename;
      document.body.appendChild(a); a.click(); document.body.removeChild(a);
    }
    download(frontImg, 'id-front.png');
    setTimeout(() => download(backImg, 'id-back.png'), 1200);
  } catch (err) {
    console.error(err); alert("Download Both failed!");
  }
}
</script>
