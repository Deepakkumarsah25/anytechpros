<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=yes">
  <title>AnyTechPros | Strategy Led · Product Driven — Fully Responsive</title>
  <link rel="stylesheet" href="css/common/footer.css">
  <!-- Google Fonts + System Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Syne:wght@600;700;800&family=Barlow:wght@400;500;600;700;800&family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
  
  <style>
    /* ---------- RESET & GLOBAL ---------- */
    *,
    *::before,
    *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --black: #0c0f0f;
      --black-soft: #121616;
      --olive: #4f7a3b;
      --olive-l: #7aa55a;
      --olive-d: #3a5c2a;
      --olive-glow: rgba(79, 122, 59, 0.18);
      --white: #ffffff;
      --gray-light: rgba(255, 255, 255, 0.75);
      --border: rgba(79, 122, 59, 0.35);
      --teal: #2d9c7c;
      --teal-l: #4bc0a0;
      --teal-d: #1e6b55;
      --ink-soft: #0b1215;
      --muted: #b0c4c2;
      --card-bg: rgba(18, 24, 27, 0.92);
      --card-border: rgba(45, 156, 124, 0.25);
    }

    html {
      scroll-behavior: smooth;
      overflow-x: hidden;
    }

    body {
      background: #0b0e0e;
      font-family: 'Inter', 'DM Sans', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
      color: var(--white);
      line-height: 1.45;
    }

    /* ---------- FIXED NAVBAR (ultra responsive) ---------- */
    .navbar {
      position: fixed;
      top: 0;
      z-index: 1000;
      width: 100%;
      background: rgba(12, 15, 15, 0.92);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      transition: background 0.2s;
    }

    .navbar::before {
      content: '';
      display: block;
      height: 2.5px;
      background: linear-gradient(90deg, var(--olive-d), var(--olive-l) 45%, var(--olive) 75%, var(--olive-d));
    }

    .nav-inner {
      width: 100%;
      padding: 0 32px;
      height: 70px;
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: 0;
    }

    /* LOGO */
    .logo-wrap {
      display: flex;
      align-items: center;
      gap: 8px;
      text-decoration: none;
      flex-shrink: 0;
      justify-self: start;
    }

    .logo-img-box {
      height: 44px;
      border-radius: 8px;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: transform 0.25s, filter 0.25s;
    }

    .logo-img-box img {
      height: 44px;
      width: auto;
      object-fit: contain;
      display: block;
    }

    .logo-wrap:hover .logo-img-box {
      transform: scale(1.03);
      filter: drop-shadow(0 0 8px var(--olive));
    }

    .logo-text {
      line-height: 1.1;
    }

    .logo-text .brand {
      font-family: 'Syne', 'DM Sans', sans-serif;
      font-size: 20px;
      letter-spacing: 3px;
      color: var(--white);
      display: block;
      font-weight: 700;
    }

    .logo-text .sub {
      font-size: 7px;
      letter-spacing: 2.2px;
      text-transform: uppercase;
      color: var(--olive-l);
      font-weight: 600;
      display: block;
      margin-top: 2px;
    }

    /* desktop nav */
    .nav-links {
      list-style: none;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 36px;
      width: 100%;
      padding: 0 12px;
      margin: 0;
    }

    .nav-links li {
      display: flex;
    }

    .nav-links a {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 8px 4px;
      color: var(--gray-light);
      text-decoration: none;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 1px;
      text-transform: uppercase;
      border-radius: 6px;
      white-space: nowrap;
      transition: color 0.2s, background 0.2s;
    }

    .nav-links a .icon {
      width: 14px;
      height: 14px;
      stroke: currentColor;
      fill: none;
      stroke-width: 2;
    }

    .nav-links a::after {
      content: '';
      position: absolute;
      bottom: -2px;
      left: 50%;
      right: 50%;
      height: 2px;
      background: var(--olive-l);
      border-radius: 2px;
      transition: left 0.22s, right 0.22s;
    }

    .nav-links a {
      position: relative;
    }

    .nav-links a:hover,
    .nav-links a.active {
      color: var(--white);
      background: var(--olive-glow);
    }

    .nav-links a:hover::after,
    .nav-links a.active::after {
      left: 12%;
      right: 12%;
    }

    .nav-actions {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-shrink: 0;
      justify-self: end;
    }

    .btn-cta {
      padding: 8px 22px;
      background: var(--olive);
      color: var(--white);
      font-family: 'Inter', 'DM Sans', sans-serif;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1.8px;
      text-transform: uppercase;
      border: none;
      border-radius: 40px;
      cursor: pointer;
      white-space: nowrap;
      transition: all 0.2s ease;
    }

    .btn-cta:hover {
      background: var(--olive-d);
      transform: translateY(-1px);
      box-shadow: 0 4px 12px rgba(79, 122, 59, 0.3);
    }

    /* hamburger */
    .hamburger {
      display: none;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      width: 42px;
      height: 42px;
      border-radius: 10px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      background: transparent;
      cursor: pointer;
      padding: 0 10px;
    }

    .hamburger:hover {
      background: var(--olive-glow);
      border-color: var(--olive);
    }

    .hamburger span {
      display: block;
      height: 2px;
      background: var(--white);
      border-radius: 2px;
      transition: transform 0.28s, opacity 0.2s;
    }

    .hamburger span:nth-child(2) {
      width: 70%;
    }

    .hamburger.open span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }

    .hamburger.open span:nth-child(2) {
      opacity: 0;
    }

    .hamburger.open span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }

    /* mobile drawer */
    .mobile-drawer {
      position: fixed;
      top: 0;
      right: 0;
      width: min(300px, 82vw);
      height: 100vh;
      background: #0e1212;
      border-left: 1px solid var(--border);
      z-index: 2000;
      transform: translateX(110%);
      transition: transform 0.34s cubic-bezier(0.6, 0, 0.2, 1);
      display: flex;
      flex-direction: column;
      overflow-y: auto;
    }

    .mobile-drawer.open {
      transform: translateX(0);
    }

    .drawer-head {
      padding: 20px 20px 16px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .drawer-logo {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .drawer-logo img {
      height: 36px;
      width: auto;
    }

    .drawer-logo .brand {
      font-family: 'Syne', sans-serif;
      font-size: 18px;
      letter-spacing: 2px;
      color: var(--white);
    }

    .drawer-logo .sub {
      font-size: 7px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--olive-l);
    }

    .drawer-close {
      width: 34px;
      height: 34px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 8px;
      background: transparent;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .drawer-close svg {
      width: 15px;
      height: 15px;
      stroke: var(--white);
      stroke-width: 2;
    }

    .drawer-nav {
      padding: 16px 0;
      flex: 1;
    }

    .drawer-nav a {
      display: flex;
      align-items: center;
      gap: 13px;
      padding: 14px 22px;
      color: var(--gray-light);
      text-decoration: none;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 1px;
      text-transform: uppercase;
      border-left: 3px solid transparent;
      transition: all 0.2s;
    }

    .drawer-nav a svg {
      width: 18px;
      height: 18px;
      stroke: currentColor;
      stroke-width: 1.8;
    }

    .drawer-nav a:hover,
    .drawer-nav a.active {
      color: var(--white);
      background: var(--olive-glow);
      border-left-color: var(--olive-l);
    }

    .drawer-footer {
      padding: 20px 22px;
      border-top: 1px solid var(--border);
    }

    .drawer-cta {
      width: 100%;
      padding: 12px;
      background: var(--olive);
      color: var(--white);
      font-family: 'Inter', sans-serif;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      border: none;
      border-radius: 40px;
      cursor: pointer;
    }

    .drawer-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.75);
      z-index: 1999;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s;
    }

    .drawer-overlay.open {
      opacity: 1;
      pointer-events: all;
    }

    /* responsive nav */
    @media (max-width: 1024px) {
      .nav-links {
        gap: 24px;
      }
      .nav-links a {
        font-size: 12px;
      }
    }

    @media (max-width: 880px) {

      .nav-links,
      .btn-cta {
        display: none;
      }

      .hamburger {
        display: flex;
      }

      .nav-inner {
        padding: 0 20px;
      }
    }

    @media (max-width: 480px) {
      .logo-img-box img {
        height: 36px;
      }

      .logo-text .sub {
        display: none;
      }

      .nav-inner {
        padding: 0 16px;
      }
    }

    /* HERO SECTION */
    .hero {
      width: 100%;
      min-height: 80vh;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 6rem 5rem 3rem 5rem;
      gap: 2rem;
      position: relative;
      z-index: 10;
    }

    .hero-left {
      flex: 1;
      max-width: 620px;
      z-index: 15;
    }

    .hero-tag {
      font-size: 12px;
      font-weight: 600;
      color: var(--teal-l);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      margin-bottom: 12px;
      background: rgba(45, 156, 124, 0.12);
      backdrop-filter: blur(4px);
      display: inline-block;
      padding: 5px 14px;
      border-radius: 40px;
    }

    .hero-title {
      font-family: 'Syne', 'Inter', sans-serif;
      font-size: clamp(32px, 5vw, 52px);
      font-weight: 800;
      color: #ffffff;
      line-height: 1.2;
      margin-bottom: 18px;
      letter-spacing: -0.01em;
    }

    .hero-desc {
      font-size: clamp(13px, 2vw, 15px);
      color: #cbdcd9;
      line-height: 1.5;
      margin-bottom: 24px;
      max-width: 500px;
    }

    .hero-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--teal);
      color: white;
      border: none;
      padding: 12px 28px;
      border-radius: 60px;
      font-family: 'DM Sans', sans-serif;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.25s ease;
      text-decoration: none;
      box-shadow: 0 6px 14px rgba(45, 156, 124, 0.3);
    }

    .hero-btn:hover {
      background: var(--teal-l);
      transform: translateY(-2px);
    }

    @media (max-width: 900px) {
      .hero {
        flex-direction: column;
        text-align: center;
        padding: 100px 1.8rem 2.5rem;
        min-height: auto;
      }

      .hero-left {
        max-width: 100%;
        text-align: center;
      }

      .hero-desc {
        margin-left: auto;
        margin-right: auto;
      }
    }

    /* ORBIT CONTAINER (fully responsive) */
    .orbit-container {
      position: relative;
      width: clamp(260px, 38vw, 380px);
      height: clamp(260px, 38vw, 380px);
      flex-shrink: 0;
      z-index: 20;
      margin: 0 auto;
    }

    .orbit-ring {
      position: absolute;
      border-radius: 50%;
      border: 1.2px solid rgba(79, 209, 138, 0.35);
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      pointer-events: none;
    }

    .center-circle {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 48%;
      height: 48%;
      border-radius: 50%;
      background: radial-gradient(ellipse at 30% 30%, #1e2b28, #051010);
      border: 2px solid var(--teal);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 25;
      box-shadow: 0 0 30px rgba(45, 156, 124, 0.3);
    }

    .center-circle svg {
      width: 80%;
      height: 80%;
    }

    .orbit-track {
      position: absolute;
      border-radius: 50%;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
    }

    #track1 {
      width: 70%;
      height: 70%;
      animation: spin-cw 16s linear infinite;
    }

    #track2 {
      width: 92%;
      height: 92%;
      animation: spin-ccw 22s linear infinite;
    }

    @keyframes spin-cw {
      to {
        transform: translate(-50%, -50%) rotate(360deg);
      }
    }

    @keyframes spin-ccw {
      to {
        transform: translate(-50%, -50%) rotate(-360deg);
      }
    }

    .icon-slot {
      position: absolute;
      width: 42px;
      height: 42px;
      pointer-events: auto;
    }

    .icon-slot .icon-wrap {
      width: 42px;
      height: 42px;
      border-radius: 14px;
      background: #ffffff;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);
      transition: transform 0.2s;
    }

    .icon-slot .icon-wrap:hover {
      transform: scale(1.08);
    }

    #track1 .icon-slot .icon-wrap {
      animation: counter-cw 16s linear infinite;
    }

    #track2 .icon-slot .icon-wrap {
      animation: counter-ccw 22s linear infinite;
    }

    @keyframes counter-cw {
      to {
        transform: rotate(-360deg);
      }
    }

    @keyframes counter-ccw {
      to {
        transform: rotate(360deg);
      }
    }

    .icon-slot svg {
      width: 28px;
      height: 28px;
      display: block;
    }

    @media (max-width: 600px) {
      .orbit-container {
        width: 250px;
        height: 250px;
      }

      .icon-slot {
        width: 36px;
        height: 36px;
      }

      .icon-slot .icon-wrap {
        width: 36px;
        height: 36px;
      }

      .icon-slot svg {
        width: 24px;
        height: 24px;
      }
    }

    /* TRUST STRIP */
    .trust-strip {
      position: relative;
      z-index: 10;
      background: rgba(10, 15, 15, 0.9);
      backdrop-filter: blur(6px);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      align-items: center;
      gap: 12px 28px;
      padding: 12px 24px;
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .trust-item {
      color: var(--teal-l);
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }

    .trust-item::before {
      content: "⚡";
      font-size: 12px;
      color: var(--olive-l);
    }

    /* ===== SERVICES SECTION — DARK THEME (like hero) ===== */
    .services-section {
      background: #0c1215;   /* matching dark background */
      border-top: 1px solid rgba(79, 122, 59, 0.3);
      padding: clamp(48px, 7vw, 80px) clamp(24px, 5vw, 80px);
      position: relative;
      z-index: 10;
    }

    .section-inner {
      max-width: 1440px;
      margin: 0 auto;
    }

    .section-label {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-family: 'Inter', monospace;
      font-size: 11px;
      font-weight: 700;
      color: var(--teal-l);
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 12px;
    }

    .section-label::before {
      content: '';
      width: 28px;
      height: 2px;
      background: var(--teal-l);
    }

    .section-title {
      font-family: 'Syne', 'Inter', sans-serif;
      font-size: clamp(28px, 4vw, 42px);
      font-weight: 800;
      color: #ffffff;
      letter-spacing: -0.02em;
      margin-bottom: 12px;
    }

    .section-sub {
      font-size: 15px;
      color: #b8cfca;
      max-width: 550px;
      margin-bottom: 44px;
    }

    .services-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(270px, 1fr));
      gap: 28px;
    }

    /* Card styling: semi-transparent dark with glassmorphism effect */
    .service-card {
      background: rgba(18, 28, 32, 0.85);
      backdrop-filter: blur(2px);
      border-radius: 28px;
      padding: 28px 26px;
      border: 1px solid rgba(45, 156, 124, 0.25);
      transition: all 0.35s cubic-bezier(0.2, 0.9, 0.4, 1.1);
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
    }

    .service-card:hover {
      transform: translateY(-8px) scale(1.02);
      border-color: var(--teal);
      background: rgba(22, 34, 38, 0.95);
      box-shadow: 0 28px 40px -12px rgba(45, 156, 124, 0.35);
    }

    .card-icon {
      font-size: 36px;
      margin-bottom: 20px;
      filter: drop-shadow(0 2px 6px rgba(0,0,0,0.3));
    }

    .service-card h3 {
      font-size: 20px;
      font-weight: 700;
      color: #f0f9f6;
      margin-bottom: 12px;
      letter-spacing: -0.2px;
    }

    .service-card p {
      font-size: 14px;
      color: #cbdcd9;
      line-height: 1.5;
    }

    /* CAPABILITY SECTION (dark theme) */
    .capability-section {
      background: #0a1013;
      border-top: 1px solid rgba(79, 122, 59, 0.3);
      padding: clamp(48px, 7vw, 80px) clamp(24px, 5vw, 80px);
      position: relative;
      z-index: 10;
    }

    .showcase-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(32px, 5vw, 64px);
      max-width: 1440px;
      margin: 0 auto;
    }

    .challenges .section-title,
    .capability-depth .section-title {
      color: var(--white);
    }

    .challenges .section-sub,
    .capability-depth .section-sub {
      color: var(--muted);
    }

    .feature-list {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .feature-item {
      display: flex;
      gap: 18px;
      align-items: flex-start;
      padding: 16px 18px;
      border-radius: 20px;
      border: 1px solid rgba(45, 156, 124, 0.2);
      background: rgba(45, 156, 124, 0.03);
      transition: all 0.25s;
    }

    .feature-item:hover {
      border-color: var(--teal);
      background: rgba(45, 156, 124, 0.08);
      transform: translateX(4px);
    }

    .feature-icon {
      font-size: 28px;
    }

    .feature-text h3 {
      font-family: 'Inter', sans-serif;
      font-size: 14px;
      font-weight: 700;
      letter-spacing: 0.8px;
      text-transform: uppercase;
      color: var(--white);
      margin-bottom: 6px;
    }

    .feature-text p {
      font-size: 13px;
      color: var(--muted);
      line-height: 1.55;
    }

    .skill-bars {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .skill-item {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .skill-info {
      display: flex;
      justify-content: space-between;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.6px;
      text-transform: uppercase;
      color: #c2dfd9;
    }

    .skill-percent {
      color: var(--teal-l);
    }

    .progress-bar-bg {
      width: 100%;
      height: 6px;
      background: rgba(255, 255, 255, 0.1);
      border-radius: 20px;
      overflow: hidden;
    }

    .progress-fill {
      height: 100%;
      width: 0%;
      background: linear-gradient(90deg, var(--teal-d), var(--teal-l));
      border-radius: 20px;
      transition: width 1s cubic-bezier(0.2, 0.9, 0.4, 1.1);
    }

    @media (max-width: 768px) {
      .showcase-grid {
        grid-template-columns: 1fr;
        gap: 48px;
      }
    }

    /* FOOTER */
    .main-footer {
      background: #050808;
      border-top: 1px solid var(--border);
      padding: 2rem 1.5rem 1.8rem;
      color: #b9cdc8;
      font-size: 12px;
      text-align: center;
    }

    .footer-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
    }

    .footer-links {
      display: flex;
