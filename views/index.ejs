      <script>
        (function initChatbot() {
          const toggleBtn = document.getElementById('chatToggleBtn');
          const chatWindow = document.getElementById('chatWindow');
          const chatMessagesDiv = document.getElementById('chatMessages');
          const chatInput = document.getElementById('chatInput');
          const sendBtn = document.getElementById('chatSendBtn');

          let isOpen = false;

          function toggleChat() {
            isOpen = !isOpen;
            if (isOpen) {
              chatWindow.classList.remove('hidden');
            } else {
              chatWindow.classList.add('hidden');
            }
          }

          function addMessage(text, sender) {
            const msgDiv = document.createElement('div');
            msgDiv.classList.add('message', sender === 'user' ? 'user-msg' : 'bot-msg');
            msgDiv.textContent = text;
            chatMessagesDiv.appendChild(msgDiv);
            chatMessagesDiv.scrollTop = chatMessagesDiv.scrollHeight;
          }

         function getBotResponse(userMsg) {
  const msg = userMsg.toLowerCase();

  if (msg.includes('hello') || msg.includes('hi') || msg.includes('hey')) {
    return "Hello! 👋 Welcome to AnyTechPros. How can I assist you today?";
  }

  // ✅ All Services Overview
  else if (msg.includes('services') || msg.includes('offer')) {
    return `We offer a wide range of services:

🏛️ E-Governance & IT – Digital transformation for public sector  
💻 Software Delivery – Full-cycle development & agile solutions  
🔐 Cyber Security – VAPT, CERT-In compliance & threat protection  
🤖 AI & Automation – Smart automation & ML solutions  
📡 Telecom Solutions – Network & OSS/BSS integration  
📊 Digital Marketing – SEO & performance marketing  
⚙️ IT Implementation – ERP & CRM deployment  
👥 HR & Manpower – Hiring & staffing solutions  

👉 Tell me which service you are interested in!`;
  }

  // ✅ Individual Services
  else if (msg.includes('e-governance') || msg.includes('government')) {
    return "🏛️ E-Governance & IT: We help government sectors with digital transformation, compliance-based architecture, and scalable IT systems.";
  }

  else if (msg.includes('software') || msg.includes('development')) {
    return "💻 Software Delivery: We provide full-cycle development, modern tech stack, agile delivery, and QA services.";
  }

  else if (msg.includes('cyber') || msg.includes('security')) {
    return "🔐 Cyber Security: We offer VAPT, CERT-In compliance, threat monitoring, and risk assessment to secure your systems.";
  }

  else if (msg.includes('ai') || msg.includes('automation')) {
    return "🤖 AI & Automation: We build intelligent automation systems and deploy machine learning models for business growth.";
  }

  else if (msg.includes('telecom') || msg.includes('network')) {
    return "📡 Telecom Solutions: We provide network infrastructure setup and OSS/BSS integration services.";
  }

  else if (msg.includes('marketing') || msg.includes('seo')) {
    return "📊 Digital Marketing: We run data-driven campaigns, SEO optimization, and performance marketing strategies.";
  }

  else if (msg.includes('erp') || msg.includes('crm') || msg.includes('implementation')) {
    return "⚙️ IT Implementation: We handle ERP & CRM deployment with seamless integration and user enablement.";
  }

  else if (msg.includes('hr') || msg.includes('manpower') || msg.includes('hiring')) {
    return "👥 HR & Manpower: We provide strategic hiring, staffing, and HR consulting solutions.";
  }

  // ✅ ID Card
  else if (msg.includes('id card')) {
    return "🪪 ID Card Solutions: We provide smart ID cards with secure credentials. Click on 'ID CARD' in the menu for more details.";
  }

  // ✅ Contact
  else if (msg.includes('contact') || msg.includes('email')) {
    return "📩 You can contact us via the CONTACT US button or email us at hello@anytechpros.com.";
  }

  // ✅ Pricing
  else if (msg.includes('price') || msg.includes('cost') || msg.includes('quote')) {
    return "💰 Pricing depends on your requirements. Share your needs and we’ll provide a custom quote.";
  }

  // ✅ Thanks
  else if (msg.includes('thanks') || msg.includes('thank')) {
    return "You're welcome! 😊 Let me know if you need anything else.";
  }

  // ❌ Default
  else {
    return "I can help you with our services like Software, AI, Cybersecurity, Marketing, etc. Please tell me what you need 😊";
  }
}

          function sendMessage() {
            const userText = chatInput.value.trim();
            if (!userText) return;
            addMessage(userText, 'user');
            chatInput.value = '';

            setTimeout(() => {
              const reply = getBotResponse(userText);
              addMessage(reply, 'bot');
            }, 400);
          }

          toggleBtn.addEventListener('click', toggleChat);
          sendBtn.addEventListener('click', sendMessage);
          chatInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') sendMessage();
          });
        })();
        const links = document.querySelectorAll(".nav-links a");


      </script>
